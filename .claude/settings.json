{
    "permissions": {
        "allow": [
            "Bash(make *)",
            "Bash(npm *)",
            "Bash(poetry *)",
            "Bash(ls *)",
            "Bash(find *)",
            "Bash(cat *)",
            "Bash(docker-compose *)",
            "Bash(docker compose *)"
        ],
        "ask": [
            "Bash(rm -rf *)"
        ]
    },
    "hooks": {
        "PostToolUse": [
            {
                "matcher": "Edit|Write",
                "hooks": [
                    {
                        "type": "command",
                        "command": ".claude/hooks/format.sh"
                    }
                ]
            }
        ]
    },
    "model": "",
    "env": {},
    "outputStyle": ""
}
