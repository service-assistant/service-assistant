{
	"expo": {
		"name": "Fixo",
		"slug": "client",
		"version": "1.0.0",
		"orientation": "default",
		"icon": "./assets/images/logo.png",
		"scheme": "client",
		"userInterfaceStyle": "automatic",
		"newArchEnabled": true,
		"ios": {
			"supportsTablet": true,
			"infoPlist": {
				"NSCameraUsageDescription": "Aplikacja wymaga dostępu do aparatu, żeby dołączać zdjęcia.",
				"NSMicrophoneUsageDescription": "Aplikacja wymaga dostępu do mikrofonu do komend głosowych.",
				"NSSpeechRecognitionUsageDescription": "Aplikacja wymaga dostępu do rozpoznawania mowy."
			}
		},
		"android": {
			"adaptiveIcon": {
				"backgroundColor": "#E6F4FE",
				"foregroundImage": "./assets/images/logo.png",
				"backgroundImage": "./assets/images/android-icon-background.png",
				"monochromeImage": "./assets/images/android-icon-monochrome.png"
			},
			"permissions": ["android.permission.CAMERA", "android.permission.RECORD_AUDIO"],
			"edgeToEdgeEnabled": true,
			"softwareKeyboardLayoutMode": "resize",
			"predictiveBackGestureEnabled": false,
			"package": "com.ziemnio.client"
		},
		"web": {
			"output": "static",
			"favicon": "./assets/images/favicon.png"
		},
		"plugins": [
			"expo-router",
			[
				"expo-splash-screen",
				{
					"image": "./assets/images/splash-icon.png",
					"imageWidth": 200,
					"resizeMode": "contain",
					"backgroundColor": "#ffffff",
					"dark": {
						"backgroundColor": "#000000"
					}
				}
			],
			[
				"expo-speech-recognition",
				{
					"microphonePermission": "Aplikacja wymaga dostępu do mikrofonu do komend głosowych.",
					"speechRecognitionPermission": "Aplikacja wymaga dostępu do rozpoznawania mowy."
				}
			],
			[
				"expo-screen-orientation",
				{
					"initialOrientation": "DEFAULT"
				}
			],
			"expo-web-browser",
			"./plugins/withHideNavigationBar",
			[
				"expo-camera",
				{
					"cameraPermission": "Aplikacja wymaga dostępu do aparatu, żeby dołączać zdjęcia."
				}
			],
			"expo-audio",
			"expo-video",
			"expo-asset"
		],
		"experiments": {
			"typedRoutes": true,
			"reactCompiler": false
		},
		"extra": {
			"router": {},
			"eas": {
				"projectId": "694de809-431b-4b51-b7da-ac1998816197"
			}
		}
	}
}
